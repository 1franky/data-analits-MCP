# Nombre de la red Docker externa compartida con Open WebUI.
AI_PLATFORM_NETWORK=ai-platform

# Publicacion local del API. El valor por defecto solo escucha en loopback.
MCP_BIND_ADDRESS=127.0.0.1
MCP_PORT=8000

# Configuracion operativa basica del contenedor.
LOG_LEVEL=info
IMAGE_TAG=0.4.0
POSTGRES_IMAGE_TAG=17.10

# Ruta interna del repositorio SQLite persistente del catálogo.
CATALOG_DB_PATH=/app/data/catalog.db
AUDIT_DB_PATH=/app/data/audit.db

# Laboratorio local exclusivamente. Sustituye estos valores antes de cualquier despliegue.
POSTGRES_LAB_ADMIN_PASSWORD=local-only-admin-change-me
POSTGRES_DEMO_PASSWORD=local-only-readonly-change-me
POSTGRES_LAB_BIND_ADDRESS=127.0.0.1
POSTGRES_LAB_PORT=5432
