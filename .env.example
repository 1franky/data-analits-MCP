# Nombre de la red Docker externa compartida con Open WebUI.
AI_PLATFORM_NETWORK=ai-platform

# Publicacion local del API. El valor por defecto solo escucha en loopback.
MCP_BIND_ADDRESS=127.0.0.1
MCP_PORT=8000

# Configuracion operativa basica del contenedor. Desde Sprint 10, LOG_LEVEL tambien configura el
# nivel de los logs JSON de la aplicacion (antes solo alimentaba el flag --log-level de uvicorn).
LOG_LEVEL=info
IMAGE_TAG=0.9.0
POSTGRES_IMAGE_TAG=17.10
QDRANT_IMAGE_TAG=v1.17.1
MARIADB_IMAGE_TAG=11.4
MONGO_IMAGE_TAG=8.0

# Ruta interna del repositorio SQLite persistente del catálogo.
CATALOG_DB_PATH=/app/data/catalog.db
AUDIT_DB_PATH=/app/data/audit.db

# Laboratorio local exclusivamente. Sustituye estos valores antes de cualquier despliegue.
POSTGRES_LAB_ADMIN_PASSWORD=local-only-admin-change-me
POSTGRES_DEMO_PASSWORD=local-only-readonly-change-me
POSTGRES_LAB_BIND_ADDRESS=127.0.0.1
POSTGRES_LAB_PORT=5432

# Sprint 5: proveedor LLM opcional compatible con OpenAI. Solo requerido si generation.enabled=true
# en connections.yaml.
LLM_API_KEY=local-only-llm-key-change-me

# Sprint 7: RAG documental opcional. Solo requerido si rag.enabled=true en connections.yaml.
EMBEDDING_API_KEY=local-only-embedding-key-change-me
DOCUMENTS_DB_PATH=/app/data/documents.db

# Sprint 9: laboratorio MariaDB local exclusivamente. Sustituye estos valores antes de cualquier
# despliegue.
MARIADB_LAB_ADMIN_PASSWORD=local-only-admin-change-me
MARIADB_DEMO_PASSWORD=local-only-readonly-change-me
MARIADB_LAB_BIND_ADDRESS=127.0.0.1
MARIADB_LAB_PORT=3306

# Sprint 9: laboratorio MongoDB local exclusivamente. Sustituye estos valores antes de cualquier
# despliegue.
MONGO_LAB_ADMIN_PASSWORD=local-only-admin-change-me
MONGO_DEMO_PASSWORD=local-only-readonly-change-me
MONGO_LAB_BIND_ADDRESS=127.0.0.1
MONGO_LAB_PORT=27017
