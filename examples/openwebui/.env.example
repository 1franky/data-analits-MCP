# Nombre de la red Docker externa compartida con data-platform-mcp.
# Debe coincidir con AI_PLATFORM_NETWORK del .env principal del servidor MCP.
AI_PLATFORM_NETWORK=ai-platform

# Publicación local de la interfaz web. El valor por defecto solo escucha en loopback.
OPEN_WEBUI_BIND_ADDRESS=127.0.0.1
OPEN_WEBUI_PORT=3000

# Etiqueta de imagen fijada. No usar "latest" salvo para probar una versión más nueva a propósito.
OPEN_WEBUI_IMAGE_TAG=v0.10.1

# Clave requerida por Open WebUI para mantener la sesión entre reinicios del contenedor.
# Genera un valor propio antes de usar esto fuera de un laboratorio local, por ejemplo con:
#   openssl rand -hex 32
WEBUI_SECRET_KEY=local-only-webui-secret-change-me
